# SmartNotes Backend — Environment Variables
# Copy this file to .env and fill in the values.

# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=SmartNotes
APP_VERSION=1.0.0
DEBUG=false

# ── Database ──────────────────────────────────────────────────────────────────
# Development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./smartnotes.db

# Production (PostgreSQL):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/smartnotes

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=10080   # 7 days
REFRESH_TOKEN_EXPIRE_MINUTES=43200  # 30 days

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (React Native dev + prod app URLs)
ALLOWED_ORIGINS=http://localhost:3000,exp://localhost:8081

# ── AI / NLP (optional) ───────────────────────────────────────────────────────
# Leave blank to use rule-based tag extraction only.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
